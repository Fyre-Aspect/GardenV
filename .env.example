

# Web API key (config.apiKey)
REACT_APP_FIREBASE_API_KEY=

# Auth domain, e.g. your-project.firebaseapp.com (config.authDomain)
REACT_APP_FIREBASE_AUTH_DOMAIN=

# Project ID (config.projectId)
REACT_APP_FIREBASE_PROJECT_ID=

# Storage bucket, e.g. your-project.appspot.com (config.storageBucket)
REACT_APP_FIREBASE_STORAGE_BUCKET=

# Cloud Messaging sender ID (config.messagingSenderId)
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=

# App ID (config.appId)
REACT_APP_FIREBASE_APP_ID=