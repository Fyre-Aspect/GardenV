# Firebase web config.
#
# In Next.js, only variables prefixed with NEXT_PUBLIC_ are exposed to browser
# code. Firebase web keys are NOT secrets — access is enforced by Auth +
# Firestore security rules — so it's fine for these to ship to the client.
#
# Copy this file to `.env.local` and fill in the values from
# Firebase console → Project settings → Your apps → SDK setup and configuration.

# Web API key (config.apiKey)
NEXT_PUBLIC_FIREBASE_API_KEY=

# Auth domain, e.g. your-project.firebaseapp.com (config.authDomain)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# Project ID (config.projectId)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Storage bucket, e.g. your-project.appspot.com (config.storageBucket)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Cloud Messaging sender ID (config.messagingSenderId)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# App ID (config.appId)
NEXT_PUBLIC_FIREBASE_APP_ID=

# Analytics measurement ID (config.measurementId) — optional
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Gemini API key for plant scanning (server-side only — NO NEXT_PUBLIC_
# prefix, so it never ships to the browser). Get one from Google AI Studio:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
