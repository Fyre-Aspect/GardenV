rules_version = '2';

// Garden V security rules.
//
// Each user owns exactly one garden document at `gardens/{uid}` holding their
// plants, tasks, and XP (see `src/components/garden-provider.tsx`). Only the
// authenticated owner may read or write it.
service cloud.firestore {
  match /databases/{database}/documents {
    match /gardens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reserved for future per-user subcollections (e.g. per-plant history).
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
